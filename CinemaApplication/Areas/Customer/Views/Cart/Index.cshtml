@model Cart

<div class="container mt-5">
    <h2 class="mb-4">Shopping Cart 🍿</h2>
    <hr />

    @if (Model == null || Model.CartItems == null || !Model.CartItems.Any())
    {
        <div class="alert alert-secondary text-center py-5">
            <h4>Your cart is empty.</h4>
            <p>Browse our latest movies and book your seat now!</p>
            <a href="/" class="btn btn-primary mt-3">Browse Movies</a>
        </div>
    }
    else
    {
        <div class="row">
            <!-- Cart Items List -->
            <div class="col-md-8">
                @foreach (var item in Model.CartItems)
                {
                    <div class="card mb-3 shadow-sm border-0">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <!-- Movie Poster -->
                                <div class="col-md-3">
                                    <img src="@item.MovieTheater.Movie.Mainimage" class="img-fluid rounded shadow-sm" alt="Movie Poster">
                                </div>
                                <!-- Movie Details -->
                                <div class="col-md-6">
                                    <h5 class="fw-bold">@item.MovieTheater.Movie.Title</h5>
                                    <p class="text-muted mb-1">
                                        <i class="bi bi-clock"></i> Show Time: @item.MovieTheater.Showtime.ToString("hh:mm tt")
                                    </p>
                                    <div class="mt-2">
                                        <strong>Selected Seats:</strong><br />
                                        @foreach (var seatItem in item.SelectedSeats)
                                        {
                                            <span class="badge bg-dark me-1">@seatItem.Seat.Row@seatItem.Seat.Number</span>
                                        }
                                    </div>
                                </div>
                                <!-- Pricing and Controls -->
                                <div class="col-md-3 text-end">
                                    <p class="h5 text-primary mb-3">$@(item.PricePerSeat * item.SeatsCount)</p>
                                    
                                    <div class="btn-group mb-2">
                                        <a asp-action="DecrementCount" asp-route-cartItemId="@item.Id" class="btn btn-outline-danger btn-sm">-</a>
                                        <span class="btn btn-light btn-sm disabled fw-bold">@item.SeatsCount</span>
                                        <a asp-action="IncrementCount" asp-route-cartItemId="@item.Id" class="btn btn-outline-success btn-sm">+</a>
                                    </div>
                                    
                                    <a asp-action="Delete" asp-route-cartItemId="@item.Id"
                                           class="btn btn-sm btn-link text-danger text-decoration-none d-block">
                                        <i class="bi bi-trash"></i> Remove
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

         
            <div class="col-md-4">
                <div class="card border-0 shadow-sm p-4 sticky-top" style="top: 20px;">
                    <h4 class="mb-4">Order Summary</h4>
                    <div class="d-flex justify-content-between mb-2">
                        <span>Subtotal</span>
                        <span>$@Model.TotalPrice</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span>Tax (VAT)</span>
                        <span>$0.00</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between mb-4">
                        <span class="h5">Total</span>
                        <span class="h4 text-primary fw-bold">$@Model.TotalPrice</span>
                    </div>
                    <button class="btn btn-success btn-lg w-100 py-3 shadow">
                        Proceed to Checkout <i class="bi bi-arrow-right"></i>
                    </button>
                    <p class="text-muted text-center mt-3 small">
                        Secure payment guaranteed.
                    </p>
                </div>
            </div>
        </div>
    }
</div>