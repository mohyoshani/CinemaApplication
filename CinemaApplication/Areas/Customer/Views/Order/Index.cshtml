@model IEnumerable<Order>

<div class="container mt-5">
    <h2 class="mb-4 text-primary"><i class="bi bi-ticket-perforated"></i> My Bookings</h2>
    <div class="table-responsive bg-white shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Order ID</th>
                    <th>Date</th>
                    <th>Total Price</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.OrderDate.ToLocalTime().ToString("MMM dd, yyyy")</td>
                        <td class="fw-bold">$@order.TotalPrice</td>
                        <td>
                            <span class="badge @(order.Status == OrderStatus.Confirmed ? "bg-success" : "bg-warning")">
                                @order.Status
                            </span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">View Ticket</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>