<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CineWave | Elegant Movie Library</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
            :root {
                --soft-bg: #f8fafc;
                --pure-white: #ffffff;
                --accent-color: #6366f1; /* Indigo soft */
                --text-main: #1e293b;
                --text-muted: #64748b;
                --input-bg: #f1f5f9;
            }

            body {
                font-family: 'Inter', sans-serif;
                background-color: var(--soft-bg);
                color: var(--text-main);
                margin: 0;
            }

            /* --- Navbar Style --- */
            .navbar {
                background-color: var(--pure-white);
                border-bottom: 1px solid #e2e8f0;
                padding: 0.8rem 0;
            }

            .navbar-brand {
                font-weight: 800;
                color: var(--accent-color) !important;
                letter-spacing: -0.5px;
            }

            /* Search Group */
            .search-group {
                max-width: 400px;
                width: 100%;
            }

            .search-input {
                background-color: var(--input-bg);
                border: 1px solid transparent;
                border-radius: 12px 0 0 12px !important;
                padding: 0.6rem 1.2rem;
                font-size: 0.9rem;
                transition: all 0.3s;
            }

                .search-input:focus {
                    background-color: #fff;
                    border-color: var(--accent-color);
                    box-shadow: none;
                }

            .btn-search {
                background-color: var(--input-bg);
                border: 1px solid transparent;
                border-left: none;
                border-radius: 0 12px 12px 0 !important;
                padding: 0 15px;
                color: var(--text-muted);
                transition: all 0.3s;
            }

                .btn-search:hover {
                    background-color: #e2e8f0;
                    color: var(--accent-color);
                }

            .nav-link-auth {
                font-weight: 600;
                font-size: 0.9rem;
                color: var(--text-main) !important;
                margin: 0 10px;
            }

            .btn-register {
                background-color: var(--accent-color);
                color: white !important;
                border-radius: 12px;
                padding: 0.6rem 1.5rem;
                transition: 0.3s;
            }

                .btn-register:hover {
                    opacity: 0.9;
                    transform: translateY(-1px);
                }

            /* --- Movie Cards --- */
            .movie-card {
                background: var(--pure-white);
                border: none;
                border-radius: 20px;
                overflow: hidden;
                transition: all 0.4s ease;
                box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02), 0 2px 4px -1px rgba(0,0,0,0.01);
                height: 100%;
            }

                .movie-card:hover {
                    transform: translateY(-10px);
                    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05);
                }

            .poster-container {
                position: relative;
                height: 380px;
                overflow: hidden;
            }

            .movie-poster {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.6s ease;
            }

            .movie-card:hover .movie-poster {
                transform: scale(1.08);
            }

            .badge-rating {
                position: absolute;
                top: 15px;
                right: 15px;
                background: rgba(255, 255, 255, 0.9);
                padding: 5px 12px;
                border-radius: 10px;
                font-weight: 700;
                font-size: 0.75rem;
                color: #f59e0b;
                backdrop-filter: blur(4px);
            }

            .card-body {
                padding: 1.5rem;
            }

            .movie-category {
                font-size: 0.75rem;
                text-transform: uppercase;
                font-weight: 700;
                color: var(--accent-color);
                margin-bottom: 0.5rem;
                display: block;
            }

            .movie-title {
                font-size: 1.15rem;
                font-weight: 700;
                margin-bottom: 0.8rem;
                color: var(--text-main);
            }

            .btn-details {
                width: 100%;
                border: 1px solid #e2e8f0;
                border-radius: 12px;
                padding: 10px;
                color: var(--text-main);
                text-decoration: none;
                font-weight: 600;
                font-size: 0.85rem;
                display: block;
                text-align: center;
                transition: 0.3s;
            }

                .btn-details:hover {
                    background-color: var(--accent-color);
                    border-color: var(--accent-color);
                    color: white;
                }

    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand fs-3" href="#">CINEWAVE</a>
        
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <div class="mx-auto mt-3 mt-lg-0 search-group">
                    <form class="input-group">
                        <input type="text" class="form-control search-input" placeholder="Search movies, actors..." aria-label="Search">
                        <button class="btn btn-search" type="submit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z" />
                            </svg>
                        </button>
                    </form>
                </div>

                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item"><a class="nav-link nav-link-auth" href="#">Login</a></li>
                    <li class="nav-item"><a class="nav-link nav-link-auth btn-register" href="#">Register</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container py-5">
        <header class="mb-5">
            <h1 class="fw-bold">Explore Library</h1>
            <p class="text-muted">Find your next favorite movie from our curated collection.</p>
        </header>
        @RenderBody()
      
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>