@model HomeMoviesVM

<div class="row g-4">
    @if (!Model.Movies.Any())
    {
        <div class="col-12 text-center mt-5">
            <h4 class="text-muted">No Movies Found</h4>
        </div>
    }
    else
    {
        @foreach (var movie in Model.Movies)
        {
            <div class="col-12 col-md-6 col-lg-3">
                <div class="movie-card">
                    <div class="poster-container">
                       
                        <img src="@Url.Content("~/Images/Admin/Movie/" + movie.Mainimage)" class="movie-poster" alt="@movie.Title">
                      
                    </div>
                    <div class="card-body">
                        
                        <span class="movie-category">@(movie.Category?.Name ?? "General")</span>
                        <h3 class="movie-title">@movie.Title</h3>
                       
                        <a asp-action="Details" asp-area="Admin" asp-controller="Movie" asp-route-id="@movie.Id" class="btn-details">View Details</a>
                    </div>
                </div>
            </div>
        }
    }
</div>

@if (Model.TotalPages > 1)
{
    <div class="row mt-5">
        <div class="col-12 d-flex justify-content-center">
            <nav aria-label="Page navigation">
                <ul class="pagination">
                  
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-query="@Model.Query">Previous</a>
                        </li>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-query="@Model.Query">@i</a>
                        </li>
                    }

                   
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-query="@Model.Query">Next</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
}