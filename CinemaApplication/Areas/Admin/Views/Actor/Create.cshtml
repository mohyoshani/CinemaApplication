@model Actor
<form action="Create" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label for="exampleFormControlInput1" class="form-label">Actor Name</label>
        <input type="text" class="form-control" name="Name" placeholder="Enter actor name">
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label for="exampleFormControlInput1" class="form-label">Actor Image</label>
        <input type="file" class="form-control" name="Image">
    </div>
    <div class="mb-3">
        <label for="exampleFormControlInput1" class="form-label">Actor Nationality</label>
        <input type="text" class="form-control" name="Nationality" placeholder="Enter actor nationality">
        <span asp-validation-for="Nationality" class="text-danger"></span>
    </div>
  
    <button type="submit" class="btn btn-primary">Submit</button>
    <a href="~/Admin/Actor/Index" class="btn btn-secondary">Back to List</a>
</form>