@model CreateMovieVM

<form action="~/Admin/Movie/Update/@Model.Movie.Id" method="post" enctype="multipart/form-data">
  
    <input type="hidden" name="Movie.Id" value="@Model.Movie.Id" />
    <input type="hidden" name="Movie.Mainimage" value="@Model.Movie.Mainimage" />

    <div class="mb-3">
        <label class="form-label">Movie Poster</label>
       
        <img src="~/images/Admin/Movie/@Model.Movie.Mainimage" alt="Movie Poster" class="form-control img-thumbnail" style="max-width: 200px;">
        </div>

        <div class="mb-3">
            <label class="form-label">Movie Title</label>
            @* ربط الحقل بـ Movie.Title *@
            <input type="text" class="form-control" name="Movie.Title" value="@Model.Movie.Title">
        </div>

        <div class="mb-3">
            <label class="form-label">Category</label>
          
            <select name="Movie.CategoryId" class="form-select">
                @foreach (var cat in Model.Categories)
                {
                    @if (cat.Id == Model.Movie.CategoryId)
                    {
                        <option value="@cat.Id" selected>@cat.Name</option>
                    }
                    else
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Change Poster Image</label>
          
            <input type="file" class="form-control" name="MainImage">
        </div>
        <div class="mb-3">
            <label class="form-label">Change Sub Images</label>
            <input type="file" class="form-control" name="SubImages" multiple>
        </div>
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Price</label>
                <input type="number" step="0.01" class="form-control" name="Movie.Price" value="@Model.Movie.Price">
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Duration (Minutes)</label>
                <input type="number" class="form-control" name="Movie.Duration" value="@Model.Movie.Duration">
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Release Date</label>
                <input type="date" class="form-control" name="Movie.ReleaseDate" value="@Model.Movie.ReleaseDate?.ToString("yyyy-MM-dd")">
            </div>
        </div>

        <div class="mb-3 form-check">
            <input type="checkbox" class="form-check-input" name="Movie.status" value="true" @(Model.Movie.status ? "checked" : "")>
            <label class="form-check-label">Active Status</label>
        </div>

        <button type="submit" class="btn btn-warning">Update Movie</button>
        <a href="~/Admin/Movie/Index" class="btn btn-secondary">Cancel</a>
    </form>