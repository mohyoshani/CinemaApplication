@model CreateMovieVM


<div class="container mt-4">
    <h2 class="text-primary mb-4">Create New Movie</h2>
    <form action="~/Admin/Movie/Create" method="post" enctype="multipart/form-data" class="card p-4 shadow-sm">
        <div class="mb-3">
            <label class="form-label fw-bold">Movie Title</label>
            <input type="text" class="form-control" name="Movie.Title" required>
            <span asp-validation-for="Movie.Title" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Description</label>
            <textarea class="form-control" name="Movie.Description" rows="3"></textarea>
            <span asp-validation-for="Movie.Description" class="text-danger"></span>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Price</label>
                <input type="number" step="0.01" class="form-control" name="Movie.Price">
                <span asp-validation-for="Movie.Price" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Duration In Minutes</label>
                <input type="number" class="form-control" name="Movie.Duration">
                <span asp-validation-for="Movie.Duration" class="text-danger"></span>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Category</label>
                <select class="form-select" name="Movie.CategoryId">
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
                 <span asp-validation-for="Movie.CategoryId" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Release Date</label>
                <input type="date" class="form-control" name="Movie.ReleaseDate">
                <span asp-validation-for="Movie.ReleaseDate" class="text-danger"></span>
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Movie Poster</label>
            <input type="file" class="form-control" name="MainImage">
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Movie Images</label>
            <input type="file" class="form-control" name="SubImages" multiple>
        </div>
        <div class="mb-3 form-check">
            <input type="checkbox" class="form-check-input" name="Movie.status" value="true" checked>
            <label class="form-check-label">Active Status</label>
            <span asp-validation-for="Movie.status" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-success"><i class="bi bi-plus-circle"></i> Create Movie</button>
        <a href="~/Admin/Movie/Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>







