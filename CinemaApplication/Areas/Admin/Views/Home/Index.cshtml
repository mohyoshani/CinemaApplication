@model HomeCountersVM

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-5 fw-bold text-dark"><i class="bi bi-speedometer2"></i> Dashboard Overview</h1>
            <p class="text-muted">Quick statistics of your Cinema Management System.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="bi bi-film fs-1"></i>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="card-subtitle mb-1">Total Movies</h6>
                        <h2 class="card-title mb-0 fw-bold">@Model.MoviesCount</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="bi bi-people-fill fs-1"></i>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="card-subtitle mb-1">Total Actors</h6>
                        <h2 class="card-title mb-0 fw-bold">@Model.ActorsCount</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-warning text-dark h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="bi bi-building fs-1"></i>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="card-subtitle mb-1">Total Cinemas</h6>
                        <h2 class="card-title mb-0 fw-bold">@Model.CinemaHallsCount</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-danger text-white h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <i class="bi bi-tags-fill fs-1"></i>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="card-subtitle mb-1">Categories</h6>
                        <h2 class="card-title mb-0 fw-bold">@Model.CategoriesCount</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 p-4 border rounded bg-light">
        <h4><i class="bi bi-lightning-charge"></i> Quick Actions</h4>
        <div class="d-flex gap-2 mt-3">
            <a href="/Admin/MovieCast/Index" class="btn btn-outline-primary">Manage Cast</a>
            <a href="/Admin/MovieTheater/Index" class="btn btn-outline-warning">Manage Showtimes</a>
        </div>
    </div>
</div>