@using Microsoft.AspNetCore.Http
@using CinemaApplication.Models
@inject IHttpContextAccessor HttpContextAccessor
@inject Microsoft.AspNetCore.Identity.UserManager<ApplicationUser> UserManager
@inject Microsoft.AspNetCore.Identity.SignInManager<ApplicationUser> SignInManager

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString();

    bool IsActive(string controller, string action = "Index", string area = "Admin")
        => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
        && string.Equals(currentArea, area, StringComparison.OrdinalIgnoreCase);

    bool IsHome = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase)
               && string.Equals(currentArea, "Admin", StringComparison.OrdinalIgnoreCase);

    // Current logged-in user
    var currentUser = await UserManager.GetUserAsync(User);
    var displayName = currentUser is not null
                         ? $"{currentUser.FirstName} {currentUser.LastName}".Trim()
                         : User.Identity?.Name ?? "Admin";
    var userInitials = currentUser is not null
                         ? $"{currentUser.FirstName?.FirstOrDefault()}{currentUser.LastName?.FirstOrDefault()}".ToUpper()
                         : "A";
    var userEmail = currentUser?.Email ?? string.Empty;
}
<!DOCTYPE html>
<html lang="en-US" dir="ltr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " | " : "")Cinema System | Admin Panel</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,500,600,700%7cPoppins:300,400,500,600,700,800,900&display=swap" rel="stylesheet">
    
    <link href="~/vendors/overlayscrollbars/OverlayScrollbars.min.css" rel="stylesheet">

    <link href="~/assets/css/theme.min.css" rel="stylesheet" id="style-default">
    <link href="~/assets/css/user.min.css" rel="stylesheet" id="user-style-default">
    <link href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
 

    @RenderSection("Styles", required: false)
</head>

<body>
    <main class="main" id="top">
        <div class="container" data-layout="container">

            <!-- ═══════════════════════════════════════════ SIDEBAR ═══ -->
            <nav class="navbar navbar-light navbar-vertical navbar-expand-xl">
                <div class="d-flex align-items-center">
                    <div class="toggle-icon-wrapper">
                        <button class="btn navbar-toggler-humburger-icon navbar-vertical-toggle"
                                data-bs-toggle="tooltip" data-bs-placement="left" title="Toggle Navigation">
                            <span class="navbar-toggle-icon"><span class="toggle-line"></span></span>
                        </button>
                    </div>
                    <a class="navbar-brand" asp-area="Admin" asp-controller="Home" asp-action="Index">
                        <div class="d-flex align-items-center py-3">
                            <span class="fas fa-film text-primary me-2"></span>
                            <span class="font-sans-serif text-primary fw-bold">Cinema</span>
                        </div>
                    </a>
                </div>

                <div class="collapse navbar-collapse" id="navbarVerticalCollapse">
                    <div class="navbar-vertical-content scrollbar">
                        <ul class="navbar-nav flex-column mb-3" id="navbarVerticalNav">

                            <!-- Dashboard -->
                            <li class="nav-item">
                                <a class="nav-link @(IsHome ? "active" : "")"
                                       asp-area="Admin" asp-controller="Home" asp-action="Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon"><span class="fas fa-chart-pie"></span></span>
                                        <span class="nav-link-text ps-1">Dashboard</span>
                                    </div>
                                </a>
                            </li>

                            <!-- ── Movies & Media ───────────────────── -->
                            <li class="nav-item">
                                <div class="row navbar-vertical-label-wrapper mt-3 mb-2">
                                    <div class="col-auto navbar-vertical-label">Movies &amp; Media</div>
                                    <div class="col ps-0"><hr class="mb-0 navbar-vertical-divider" /></div>
                                </div>

                                <a class="nav-link @(IsActive("Movie") ? "active" : "")"
                                       asp-area="Admin" asp-controller="Movie" asp-action="Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon"><span class="fas fa-film"></span></span>
                                        <span class="nav-link-text ps-1">Movies List</span>
                                    </div>
                                </a>

                                <a class="nav-link @(IsActive("Category") ? "active" : "")"
                                       asp-area="Admin" asp-controller="Category" asp-action="Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon"><span class="fas fa-tags"></span></span>
                                        <span class="nav-link-text ps-1">Categories</span>
                                    </div>
                                </a>

                                <a class="nav-link @(IsActive("Actor") ? "active" : "")"
                                       asp-area="Admin" asp-controller="Actor" asp-action="Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon"><span class="fas fa-users"></span></span>
                                        <span class="nav-link-text ps-1">Actors</span>
                                    </div>
                                </a>

                                <a class="nav-link @(IsActive("MovieCast") ? "active" : "")"
                                       asp-area="Admin" asp-controller="MovieCast" asp-action="Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon"><span class="fas fa-user-tag"></span></span>
                                        <span class="nav-link-text ps-1">Movie Casting</span>
                                    </div>
                                </a>
                            </li>

                            <!-- ── Infrastructure ──────────────────── -->
                            <li class="nav-item">
                                <div class="row navbar-vertical-label-wrapper mt-3 mb-2">
                                    <div class="col-auto navbar-vertical-label">Infrastructure</div>
                                    <div class="col ps-0"><hr class="mb-0 navbar-vertical-divider" /></div>
                                </div>

                                <a class="nav-link @(IsActive("CinemaHall") ? "active" : "")"
                                       asp-area="Admin" asp-controller="CinemaHall" asp-action="Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon"><span class="fas fa-door-open"></span></span>
                                        <span class="nav-link-text ps-1">Cinema Halls</span>
                                    </div>
                                </a>
                            </li>

                            <!-- ── Bookings ─────────────────────────── -->
                            <li class="nav-item">
                                <div class="row navbar-vertical-label-wrapper mt-3 mb-2">
                                    <div class="col-auto navbar-vertical-label">Operations</div>
                                    <div class="col ps-0"><hr class="mb-0 navbar-vertical-divider" /></div>
                                </div>

                                <a class="nav-link @(IsActive("MovieTheater") ? "active" : "")"
                                       asp-area="Admin" asp-controller="MovieTheater" asp-action="Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon"><span class="fas fa-calendar-alt"></span></span>
                                        <span class="nav-link-text ps-1">Showtimes</span>
                                    </div>
                                </a>
                            </li>

                            <!-- ── Users ───────────────────────────────── -->
                            <li class="nav-item">
                                <div class="row navbar-vertical-label-wrapper mt-3 mb-2">
                                    <div class="col-auto navbar-vertical-label">Users</div>
                                    <div class="col ps-0"><hr class="mb-0 navbar-vertical-divider" /></div>
                                </div>

                                <a class="nav-link @(IsActive("User") ? "active" : "")"
                                       asp-area="Admin" asp-controller="User" asp-action="Index">
                                    <div class="d-flex align-items-center">
                                        <span class="nav-link-icon"><span class="fas fa-users-cog"></span></span>
                                        <span class="nav-link-text ps-1">Manage Users</span>
                                    </div>
                                </a>
                            </li>

                        </ul>
                    </div>
                </div>
            </nav>
            <!-- ═══════════════════════════════════════ END SIDEBAR ═══ -->

            <div class="content">

                <!-- ════════════════════════════════ TOP NAVBAR ════════ -->
                <nav class="navbar navbar-light navbar-glass navbar-top navbar-expand">
                    <button class="btn navbar-toggler-humburger-icon navbar-toggler me-1 me-sm-3"
                            type="button" data-bs-toggle="collapse"
                            data-bs-target="#navbarVerticalCollapse"
                            aria-controls="navbarVerticalCollapse"
                            aria-expanded="false" aria-label="Toggle Navigation">
                        <span class="navbar-toggle-icon"><span class="toggle-line"></span></span>
                    </button>

                    <!-- Breadcrumb / Page title -->
                    <div class="navbar-nav align-items-center d-none d-sm-flex">
                        <span class="text-500 fs--1">
                            <span class="fas fa-home me-1"></span>
                            @Html.Raw(ViewData["Breadcrumb"] ?? "Dashboard")
                        </span>
                    </div>

                    <ul class="navbar-nav navbar-nav-icons ms-auto flex-row align-items-center">

                        <!-- Live clock -->
                        <li class="nav-item d-none d-md-flex me-3">
                            <span class="fs--1 text-500 fw-semi-bold" id="liveClock"></span>
                        </li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <!-- ── Logged-in: avatar dropdown ── -->
                            <li class="nav-item dropdown">
                                <a class="nav-link pe-0" id="navbarDropdownUser" href="#"
                                       role="button" data-bs-toggle="dropdown"
                                       aria-haspopup="true" aria-expanded="false">
                                    <div class="avatar avatar-xl d-flex align-items-center justify-content-center
                                        rounded-circle bg-primary text-white fw-bold"
                                         style="width:36px;height:36px;font-size:.85rem;">
                                        @userInitials
                                    </div>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end py-0"
                                     aria-labelledby="navbarDropdownUser">
                                    <div class="bg-white dark__bg-1000 rounded-2 py-2">

                                        <!-- User info header -->
                                        <div class="px-3 py-2 border-bottom">
                                            <p class="mb-0 fw-semibold text-dark">@displayName</p>
                                            <small class="text-muted">@userEmail</small>
                                        </div>

                                        <!-- Profile → Identity/Profile/Update -->
                                        <a class="dropdown-item @(IsActive("Profile", "Update", "Identity") ? "active" : "")"
                                               asp-area="Identity" asp-controller="Profile" asp-action="Update">
                                            <span class="fas fa-user-edit me-2 text-500"></span>My Profile
                                        </a>

                                        <div class="dropdown-divider"></div>

                                        <!-- Logout → Identity/Account/Logout -->
                                        <form asp-area="Identity" asp-controller="Account" asp-action="Logout"
                                              method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger">
                                                <span class="fas fa-sign-out-alt me-2"></span>Logout
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </li>
                        }
                        else
                        {
                            <!-- ── Guest: Login + Register buttons ── -->
                            <li class="nav-item me-2">
                                <a class="btn btn-sm btn-outline-primary @(IsActive("Account", "Login", "Identity") ? "active" : "")"
                                       asp-area="Identity" asp-controller="Account" asp-action="Login">
                                    <span class="fas fa-sign-in-alt me-1"></span>Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-sm btn-primary @(IsActive("Account", "Register", "Identity") ? "active" : "")"
                                       asp-area="Identity" asp-controller="Account" asp-action="Register">
                                    <span class="fas fa-user-plus me-1"></span>Register
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
                <!-- ══════════════════════════ END TOP NAVBAR ══════════ -->
                <!-- Page Content -->
                <div class="mt-4">
                    @RenderBody()
                </div>

                <footer class="footer">
                    <div class="row g-0 justify-content-between fs--1 mt-4 mb-3">
                        <div class="col-12 col-sm-auto text-center">
                            <p class="mb-0 text-600">
                                Cinema Management System &copy; @DateTime.Now.Year
                                <span class="d-none d-sm-inline-block"> | </span>
                                <span class="d-none d-sm-inline-block">All Rights Reserved</span>
                            </p>
                        </div>
                    </div>
                </footer>
            </div>

        </div>
    </main>

    <!-- ═══════════════════════════════════════════ SCRIPTS ═══════════ -->
    <script src="~/lib/jquery/dist/jquery.js"></script>

    <script src="~/vendors/popper/popper.min.js"></script>
    <script src="~/vendors/bootstrap/bootstrap.min.js"></script>
    <script src="~/vendors/anchorjs/anchor.min.js"></script>
    <script src="~/vendors/is/is.min.js"></script>
    <script src="~/vendors/fontawesome/all.min.js"></script>
    <script src="~/vendors/lodash/lodash.min.js"></script>
    <script src="~/vendors/overlayscrollbars/OverlayScrollbars.min.js"></script>
    <script src="~/assets/js/theme.js"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>


    <!-- Live Clock -->
    <script>
            (function () {
                const el = document.getElementById('liveClock');
                if (!el) return;
                function tick() {
                    const now = new Date();
                    el.textContent = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                }
                tick();
                setInterval(tick, 1000);
            })();
    </script>

    @RenderSection("Scripts", required: false)
    <partial name="_ValidationScriptsPartial" />
    <partial name="_NotificationPartial" />
</body>
</html>
