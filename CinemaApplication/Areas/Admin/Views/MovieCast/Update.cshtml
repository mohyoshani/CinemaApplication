@model AssignCastVM

<div class="container mt-5">
    <div class="card shadow-sm border-warning">
        <div class="card-header bg-warning text-dark">
            <h3 class="mb-0"><i class="bi bi-pencil-square"></i> Update Movie Cast</h3>
        </div>
        <div class="card-body">
              
               
                <form asp-action="Update" asp-controller="MovieCast" asp-area="Admin" asp-route-id="@Model.MovieId" method="post">
                <div class="row">
                    <h5 class="mb-3">Edit Selected Actors:</h5>
                    @foreach (var actor in Model.Actors)
                    {
                        <div class="col-md-4 mb-2">
                            <div class="form-check p-2 border rounded">
                                <input class="form-check-input ms-1" type="checkbox"
                                       name="SelectedActorsIds"
                                       value="@actor.Id"
                                       id="actor_@actor.Id"
                                @(Model.SelectedActorsIds != null && Model.SelectedActorsIds.Contains(actor.Id) ? "checked" : "")>
                                <label class="form-check-label ms-4" for="actor_@actor.Id">
                                    @actor.Name
                                </label>
                            </div>
                        </div>
                    }
                </div>

                <hr />
                <div class="mt-3">
                    <button type="submit" class="btn btn-warning px-4">Update Cast</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>