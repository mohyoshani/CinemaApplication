@model MovieCastVM


<div class="container pb-5">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 class="text-primary"><i class="bi bi-people-fill"></i>Cast Movies List</h2>
        </div>
     @*    <div class="col-md-6 text-end">
            <a href="~/Admin/MovieCast/Create" class="btn btn-success shadow-sm">
                <i class="bi bi-plus-circle"></i> Assign Cast
            </a>
        </div> *@
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3" action="~/Admin/MovieCast/Index/">
                <div class="col-md-8">
                    <input type="text" name="query" class="form-control" placeholder="Search by movie name or category ..." value="@Model.Query" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">Index</th>
                        <th>Category</th>
                        <th>Title</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int count = 1;
                    }
                    @foreach (var cast in Model.movies)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">@((Model.CurrentPage-1) * 5 + count)</td>
                            <td>@cast.Category.Name</td>
                            <td>@cast.Title</td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a href="~/Admin/movieCast/Create?movieid=@cast.Id" class="btn btn-success shadow-sm">
                                        <i class="bi bi-plus-circle"></i> Assign Cast
                                    </a>
                                    <a href="~/Admin/movieCast/Update/@cast.Id" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil-square"></i> Edit Cast
                                    </a>
                                    <a href="~/Admin/movieCast/Details/@cast.Id" class="btn btn-sm btn-outline-info">
                                        <i class="bi bi-info-circle"></i> Cast Details
                                    </a>
                                  
                                    <form action="/Admin/MovieCast/Delete/@cast.Id" method="post" class="delete-form">
                                        <button type="button" class="btn btn-sm btn-outline-danger btn-delete">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        count++;
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="row" style="margin-top: 20px;">
        <div class="col-12 d-flex justify-content-center">
            <nav aria-label="Page navigation example">
                <ul class="pagination justify-content-center">
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item"><a class="page-link" href="/Admin/MovieCast/Index?page=@(Model.CurrentPage - 1)">Previous</a></li>
                    }
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        @if (i == Model.CurrentPage)
                        {
                            <li class="page-item active"><a class="page-link" href="/Admin/MovieCast/Index?page=@i">@i</a></li>
                        }
                        else
                        {
                            <li class="page-item"><a class="page-link" href="/Admin/MovieCast/Index?page=@i">@i</a></li>
                        }
                    }
                    @if (Model.CurrentPage != Model.TotalPages)
                    {
                        <li class="page-item"><a class="page-link" href="/Admin/MovieCast/Index?page=@(Model.CurrentPage + 1)">Next</a></li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.btn-delete').forEach(button => {
        button.addEventListener('click', function () {
            const form = this.closest('.delete-form');
            Swal.fire({
                title: 'Are you sure?',
                text: "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit(); //
                }
            });
        });
    });
</script>