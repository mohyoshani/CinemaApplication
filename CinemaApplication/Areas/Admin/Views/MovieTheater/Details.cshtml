@model Movie

<div class="container mt-5 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary"><i class="bi bi-info-circle-fill"></i> Movie Theater Details</h2>
        <div class="gap-2">
            <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil-square"></i> Edit Theater
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <h3 class="card-title fw-bold">@Model.Title</h3>
                    <span class="badge bg-info text-dark mb-3">@Model.Category.Name</span>
                    <p class="text-muted">Explore Movie Theaters</p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="bi bi-people"></i> Movie Cast Members</h5>
                </div>
                <div class="card-body">
                    @if (Model.MovieTheaters != null && Model.MovieTheaters.Any())
                    {
                        <div class="row row-cols-1 row-cols-md-2 g-3">
                            @foreach (var movieTheater in Model.MovieTheaters)
                            {
                                <div class="col">
                                    <div class="d-flex align-items-center p-3 border rounded shadow-sm bg-light">
                                        <div class="flex-shrink-0">
                                            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white" style="width: 50px; height: 50px;">
                                                <i class="bi bi-person-fill fs-4"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1 ms-3">
                                            <h6 class="mb-0 fw-bold">@movieTheater.CinemaHall.Name</h6>
                                            <small class="text-muted">Showtime: @movieTheater.Showtime</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-triangle"></i> No theaters assigned to this movie yet.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>