@* @* @model MovieVM
<div class="container pb-5">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 class="text-primary"><i class="bi bi-film"></i> Movies List</h2>
        </div>
        <div class="col-md-6 text-end">
            <a href="~/Admin/Movie/Create" class="btn btn-success shadow-sm">
                <i class="bi bi-plus-circle"></i> Create New Movie
            </a>
        </div>
    </div>

 
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3" action="~/Admin/Movie/Index/">
                <div class="col-md-8">
                    <input type="text" name="query" class="form-control" placeholder="Search by title ..." value="@Model.Query" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int count = 1;
                    }
                    @foreach (var movie in Model.Movies)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">@((Model.CurrentPage - 1) * 5 + count)</td>
                            <td class="fw-bold">@movie.Title</td>
                            <td>
                                <span class="badge bg-info text-dark">
                                    @(movie.Category?.Name ?? "No Category")
                                </span>
                            </td>
                            <td>@movie.Price?.ToString("0.00") LE</td>
                            <td>
                                @if (movie.status)
                                {
                                    <span class="badge bg-success">@movie.status</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@movie.status</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a href="~/Admin/Movie/Update/@movie.Id" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <form action="/Admin/Movie/Delete/@movie.Id" method="post" class="delete-form">
                                        <button type="button" class="btn btn-sm btn-outline-danger btn-delete">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        count++;
                    }
                </tbody>
            </table>
        </div>
    </div>
    </div>

    @* Pagination *@
@*     <div class="row mt-4">
        <div class="col-12 d-flex justify-content-center">
            <nav>
                <ul class="pagination">
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/Admin/Movie/Index?page=@(Model.CurrentPage - 1)&query=@Model.Query">Previous</a>
                        </li>
                    }
                    @for (var i = 1; i <= Model.totalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="/Admin/Movie/Index?page=@i&query=@Model.Query">@i</a>
                        </li>
                    }
                    @if (Model.CurrentPage != Model.totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/Admin/Movie/Index?page=@(Model.CurrentPage + 1)&query=@Model.Query">Next</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.btn-delete').forEach(button => {
        button.addEventListener('click', function () {
            const form = this.closest('.delete-form');
            Swal.fire({
                title: 'Are you sure?',
                text: "You are about to delete this movie!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!'
            }).then((result) => {
                if (result.isConfirmed) form.submit();
            });
        });
    });
</script> *@
