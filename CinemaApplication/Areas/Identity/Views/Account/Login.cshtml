@model CinemaApplication.ViewModels.LoginVM

@{
    ViewData["Title"] = "Login";
    Layout = "~/Areas/Identity/Views/Shared/_IdentityLayout.cshtml";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow-lg border-0 rounded-lg mt-5">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3 class="font-weight-light my-1">Login</h3>
                    <p class="mb-0 text-white-50">Welcome back! Please login to your account.</p>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="UserNameOrEmail" class="form-control" placeholder="Username or Email" />
                            <label asp-for="UserNameOrEmail">Username or Email</label>
                            <span asp-validation-for="UserNameOrEmail" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                            <label asp-for="Password">Password</label>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" asp-for="RememberMe" />
                            <label class="form-check-label" asp-for="RememberMe">
                                @Html.DisplayNameFor(m => m.RememberMe)
                            </label>
                        </div>

                        <div class="d-grid mt-4 mb-0">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm">
                                <i class="fas fa-sign-in-alt me-2"></i> Login
                            </button>
                        </div>
                    </form>
                </div>

                <div class="card-footer text-center py-3 bg-light">

                    <div class="small">
                        <p class="mb-1">Do you Forget Passwrod? <a asp-action="ForgetPassword" class="text-decoration-none">Forget Password!</a></p>
                      
                    </div>
                    <div class="small">
                        <p class="mb-1">Confirm Your Email Address! <a asp-action="ConfirmEmail" class="text-decoration-none">Email Confirmation!</a></p>
                       
                    </div>
                    <div class="small">
                        <p class="mb-1">Don't have an account? <a asp-action="Register" class="text-decoration-none">Register!</a></p>
                        <a asp-controller="Home" asp-action="Index" asp-area="Admin" class="text-muted small">
                            Return to Home
                        </a>
                    </div>
                  
                </div>
            </div>
        </div>
    </div>
</div>

